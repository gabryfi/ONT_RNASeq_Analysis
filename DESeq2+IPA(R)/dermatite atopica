#!/usr/bin/env Rscript

suppressMessages({
  library(DESeq2)
  library(stringr)
  library(tools)
  library(pheatmap)
  library(ggplot2)
  library(matrixStats)
  library(RColorBrewer)
  library(dplyr) # Caricato per allineamento alle funzioni di LORE (es. %>%)
})

# === PARAMETRI DA TERMINALE ===
args <- commandArgs(trailingOnly = TRUE)

if (length(args) != 3) {
  stop("Uso corretto: Rscript deseq_auto_import.R <WORK_DIR> <TREATMENT_LABEL> <CONTROL_LABEL>")
}

work_dir  <- args[1]
treatment <- args[2]
control   <- args[3]

# === 1. LETTURA FILE CONTEGGI ===
count_files <- list.files(work_dir, pattern = "_counts\\.txt$", full.names = TRUE)
if (length(count_files) == 0) stop("Nessun file *_counts.txt trovato nella cartella di lavoro.")

# Estrazione metadati dal nome del file
extract_metadata <- function(filename) {
  base <- basename(filename)
  name <- file_path_sans_ext(base)
  parts <- str_split(name, "_")[[1]]
  
  batch     <- parts[1]
  barcode   <- parts[3]
  condition <- parts[4]
  sample    <- paste(batch, "bc", barcode, condition, sep = "_")
  
  return(data.frame(sample = sample, batch = batch, condition = condition, file = filename, stringsAsFactors = FALSE))
}

sample_table <- do.call(rbind, lapply(count_files, extract_metadata))

# Lettura delle matrici di featureCounts
read_featureCounts <- function(file_path) {
  df <- read.table(file_path, header = TRUE, skip = 1, row.names = 1)
  count_col <- df[, ncol(df), drop = FALSE]
  colnames(count_col) <- file_path_sans_ext(basename(file_path))
  return(count_col)
}

count_list <- lapply(sample_table$file, read_featureCounts)
count_matrix <- do.call(cbind, count_list)

# Allineamento perfetto sample_table <-> count_matrix
sample_table$raw_sample <- file_path_sans_ext(basename(sample_table$file))
sample_table <- sample_table[match(colnames(count_matrix), sample_table$raw_sample), ]

sample_table$batch <- as.factor(sample_table$batch)
sample_table$condition <- as.factor(sample_table$condition)

# === 2. COSTRUZIONE OGGETTO DESEQ2 & FILTRAGGIO (ALLINEATO A LORE) ===
if (length(unique(sample_table$batch)) > 1) {
  design_formula <- ~ batch + condition
} else {
  design_formula <- ~ condition
}

dds <- DESeqDataSetFromMatrix(
  countData = round(count_matrix),
  colData = sample_table[, c("sample", "batch", "condition")],
  design = design_formula
)

# [FILTRO LORE]: Mantiene solo i geni che hanno un totale di almeno 10 reads tra tutti i campioni
cat("[INFO] Applicazione filtro di LORE: rimozione geni con rowSums < 10...\n")
keep <- rowSums(counts(dds)) >= 10
dds <- dds[keep, ]

# === 3. ANALISI STATISTICA ===
dds <- DESeq(dds)
res <- results(dds, contrast = c("condition", treatment, control))

# Salvataggio output grezzi tabellari
write.csv(as.data.frame(res), file = file.path(work_dir, "deseq_results.csv"))
write.csv(sample_table, file = file.path(work_dir, "samples_metadata.csv"), row.names = FALSE)

# === 4. GENERAZIONE MATRICE PRONTA PER IPA (QIAGEN) ===
cat("[INFO] Generazione del file di input ottimizzato per IPA Qiagen...\n")
res_df <- as.data.frame(res)

# Calcolo matematico del Fold Change Lineare classico partendo dal log2FC
res_df$Fold_Change_Linear <- ifelse(res_df$log2FoldChange >= 0, 
                                    2^(res_df$log2FoldChange), 
                                    -1 / (2^(res_df$log2FoldChange)))

contrast_suffix <- paste0(treatment, "_vs_", control)
ipa_input <- data.frame(
  Gene_ID = rownames(res_df),
  Expr_Log2_Fold_Change = res_df$log2FoldChange,
  Expr_Fold_Change = res_df$Fold_Change_Linear,
  Expr_p_value = res_df$pvalue,
  Expr_FDR = res_df$padj,
  stringsAsFactors = FALSE
)

colnames(ipa_input) <- c(
  "Gene_ID", 
  paste0("Expr Log2 Fold Change ", contrast_suffix),
  paste0("Expr Fold Change ", contrast_suffix),
  paste0("Expr p-value ", contrast_suffix),
  paste0("Expr FDR ", contrast_suffix)
)

write.table(
  ipa_input,
  file = file.path(work_dir, paste0("IPA_ready_input_", contrast_suffix, ".txt")),
  sep = "\t",
  quote = FALSE,
  row.names = FALSE
)

# === 5. GRAFICI: PCA & HEATMAP ===
rld <- rlog(dds, blind = FALSE)
pcaData <- plotPCA(rld, intgroup = "condition", returnData = TRUE)
percentVar <- round(100 * attr(pcaData, "percentVar"))

p_pca <- ggplot(pcaData, aes(PC1, PC2, color = condition)) +
  geom_point(size = 4) +
  xlab(paste0("PC1: ", percentVar[1], "%")) +
  ylab(paste0("PC2: ", percentVar[2], "%")) +
  theme_minimal() +
  ggtitle("PCA Plot")
ggsave(filename = file.path(work_dir, "PCA_plot.png"), plot = p_pca, width = 6, height = 5)

top_genes <- head(order(rowVars(assay(rld)), decreasing = TRUE), 30)
mat <- assay(rld)[top_genes, ]
mat <- mat - rowMeans(mat)
anno <- as.data.frame(colData(rld)[, c("condition", "batch")])
pheatmap(mat, annotation_col = anno,
         fontsize_row = 8, cluster_cols = TRUE,
         filename = file.path(work_dir, "Heatmap_top30.png"))

# === 6. GRAFICO: VOLCANO PLOT (ALLINEATO A PARAMETRI E COLORI LORE) ===
cat("[INFO] Generazione Volcano Plot con impostazioni grafiche di LORE...\n")

# Creazione del set di dati specifico per il Volcano (chiamato 'vol' come fa LORE)
vol <- as.data.frame(res)
vol$ID <- rownames(vol)
vol$lfc <- vol$log2FoldChange

# Definizione dei tre gruppi di categorizzazione e colorazione di LORE (padj < 0.05 e |log2FC| > 1)
vol$gene_type <- "Not Significant"
vol$gene_type[vol$lfc > 1 & vol$padj < 0.05] <- "Upregulated"
vol$gene_type[vol$lfc < -1 & vol$padj < 0.05] <- "Downregulated"

# Conversione a fattore per bloccare i livelli grafici
vol$gene_type <- factor(vol$gene_type, levels = c("Upregulated", "Downregulated", "Not Significant"))

# Creazione del plot applicando i parametri di LORE: xlim(-20,20), alpha e shape dedicati
volcano_plot <- vol %>%
  filter(!is.na(padj)) %>% # Rimuove i valori NA per evitare buchi nel grafico
  ggplot(aes(x = lfc,
             y = -log10(padj),
             colour = gene_type,    
             size = gene_type,
             alpha = gene_type)) + 
  geom_point(shape = 16) +  
  xlim(-20, 20) + # [BLOCCO ASSE LORE]
  scale_colour_manual(values = c("Upregulated" = "red", 
                                 "Downregulated" = "blue", 
                                 "Not Significant" = "grey")) +
  scale_size_manual(values = c("Upregulated" = 2, 
                               "Downregulated" = 2, 
                               "Not Significant" = 1)) +
  scale_alpha_manual(values = c("Upregulated" = 1, 
                                "Downregulated" = 1, 
                                "Not Significant" = 0.4)) +
  theme_minimal() +
  xlab("log2 Fold Change") +
  ylab("-log10 adjusted p-value") +
  ggtitle(paste0("Volcano Plot: ", contrast_suffix)) +
  theme(legend.title = element_blank())

# Salvataggio del grafico Volcano in PNG (e anche in SVG come faceva LORE)
ggsave(file.path(work_dir, "Volcano_plot.png"), plot = volcano_plot, width = 7, height = 6)
svg(file.path(work_dir, "volcano_labelled.svg"), width = 8, height = 8)
print(volcano_plot)
dev.off()

cat("[SUCCESS] Script R completato. Tutti i file salvati nella cartella di lavoro.\n")
