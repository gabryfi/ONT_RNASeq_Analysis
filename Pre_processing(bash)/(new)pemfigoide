#!/usr/bin/env bash

set -Eeuo pipefail
IFS=$'\n\t'
shopt -s nullglob

# ==============================================================================
# PIPELINE NANOPORE BULK RNA-SEQ — SEMPLICE, ROBUSTA E RIAVVIABILE
#
# FASTQ per barcode -> fastcat -> Pychopper -> minimap2/samtools
# -> featureCounts -> DESeq2
#
# Questa copia è già configurata per riprendere:
#   /home/lab-user/Scrivania/dermatite/Batch1_bulk_output_20260721_105453
#
# Basta eseguire lo script: gli output già completati vengono riutilizzati.
# ==============================================================================

# --- Parametri principali ------------------------------------------------------
FASTQ_DIR="${FASTQ_DIR:-/home/lab-user/Scrivania/pemfigoide/fastq_pass}"

CONTROL_LABEL="${CONTROL_LABEL:-SANO}"
TREATMENT_LABEL="${TREATMENT_LABEL:-PB}"

CONTROL_BARCODES=(01 02 03 04 05 06)
TREATMENT_BARCODES=(07 08 09 10 11 13)

BATCH_NAME="${BATCH_NAME:-Batch1}"
THREADS="${THREADS:-50}"

# Cartella della lavorazione da riprendere. Può ancora essere sovrascritta
# passando OUTPUT_ROOT=/altro/percorso prima del comando.
OUTPUT_ROOT="${OUTPUT_ROOT:-/home/lab-user/Scrivania/pemfigoide/Batch1_bulk_output_20260721_105453}"

# Script R robusto usato alla fine della pipeline.
R_SCRIPT="${R_SCRIPT:-/home/lab-user/Scrivania/deseq_auto_import_robusto.r}"
REF="${REF:-/home/lab-user/reference/Homo_sapiens.GRCh38.dna.primary_assembly.fa}"
GTF="${GTF:-/home/lab-user/reference/gtf_human/BULK_HUMAN_G38.gtf}"

CONDA_BASE="${CONDA_BASE:-/home/lab-user/miniforge3}"

MIN_LENGTH="${MIN_LENGTH:-500}"
MIN_QSCORE="${MIN_QSCORE:-10}"
FEATURECOUNTS_STRAND="${FEATURECOUNTS_STRAND:-0}"
RUN_DESEQ2="${RUN_DESEQ2:-1}"

# Vuoto = kit predefinito di Pychopper.
PYCHOPPER_KIT="${PYCHOPPER_KIT:-}"

# --- Ambienti ed eseguibili ---------------------------------------------------
MAIN_ENV="${CONDA_BASE}/envs/nanopore_bulk_stable"
PYCHOPPER_ENV="${CONDA_BASE}/envs/nanopore_pychopper"
FASTCAT_ENV="${CONDA_BASE}/envs/nanopore_fastcat"
R_ENV="${CONDA_BASE}/envs/nanopore_deseq2"

FASTCAT="${FASTCAT_ENV}/bin/fastcat"
PYCHOPPER="${PYCHOPPER_ENV}/bin/pychopper"
NHMMSCAN="${PYCHOPPER_ENV}/bin/nhmmscan"
MINIMAP2="${MAIN_ENV}/bin/minimap2"
SAMTOOLS="${MAIN_ENV}/bin/samtools"
FEATURECOUNTS="${MAIN_ENV}/bin/featureCounts"
RSCRIPT="${R_ENV}/bin/Rscript"

CURRENT_SAMPLE="inizializzazione"
CURRENT_STAGE="controlli iniziali"
CURRENT_TMP_DIR=""

on_error() {
    local status=$?

    if [[ -n "${CURRENT_TMP_DIR}" && -d "${CURRENT_TMP_DIR}" ]]; then
        rm -rf "${CURRENT_TMP_DIR}" 2>/dev/null || true
    fi

    printf '\nERRORE: pipeline interrotta.\n' >&2
    printf '  Campione: %s\n' "${CURRENT_SAMPLE}" >&2
    printf '  Fase    : %s\n' "${CURRENT_STAGE}" >&2
    printf '  Riga    : %s\n' "${BASH_LINENO[0]:-?}" >&2
    printf '  Codice  : %s\n' "${status}" >&2
    printf 'Puoi rilanciare la stessa cartella OUTPUT_ROOT: gli step completi saranno saltati.\n' >&2
    exit "${status}"
}
trap on_error ERR

die() {
    printf 'ERRORE: %s\n' "$*" >&2
    exit 1
}

warn() {
    printf 'ATTENZIONE: %s\n' "$*" >&2
}

require_executable() {
    [[ -x "$1" ]] || die "Eseguibile non trovato: $1"
}

require_readable_file() {
    [[ -f "$1" && -r "$1" ]] || die "File non trovato o non leggibile: $1"
}

require_nonempty_file() {
    [[ -s "$1" ]] || die "Output assente o vuoto: $1"
}

sample_name() {
    printf '%s_barcode_%s_%s' "${BATCH_NAME}" "$1" "$2"
}

check_readable_fastq() {
    local barcode_dir="$1"
    local first_fastq

    [[ -d "${barcode_dir}" && -r "${barcode_dir}" && -x "${barcode_dir}" ]] \
        || die "Cartella non leggibile: ${barcode_dir}"

    first_fastq="$(
        find "${barcode_dir}" \
            -type f \
            \( \
                -iname '*.fastq.gz' -o \
                -iname '*.fq.gz'    -o \
                -iname '*.fastq'    -o \
                -iname '*.fq' \
            \) \
            -readable \
            -print \
            -quit 2>/dev/null || true
    )"

    [[ -n "${first_fastq}" ]] \
        || die "Nessun FASTQ leggibile trovato in ${barcode_dir}"
}

run_fastcat() {
    env PATH="${FASTCAT_ENV}/bin:${PATH}" "${FASTCAT}" "$@"
}

run_pychopper() {
    # Pychopper richiama nhmmscan come processo esterno.
    env PATH="${PYCHOPPER_ENV}/bin:${PATH}" "${PYCHOPPER}" "$@"
}

process_sample() {
    local barcode="$1"
    local label="$2"
    local sample barcode_dir
    local filtered_fastq full_length_fastq sorted_bam counts_file
    local filtered_tmp full_length_tmp bam_tmp counts_tmp
    local sample_tmp
    local -a pychopper_args

    sample="$(sample_name "${barcode}" "${label}")"
    barcode_dir="${FASTQ_DIR}/barcode${barcode}"

    filtered_fastq="${FASTCAT_DIR}/${sample}_filtered.fastq"
    full_length_fastq="${PYCHOPPER_DIR}/${sample}_full_length.fastq"
    sorted_bam="${BAM_DIR}/${sample}_sorted.bam"
    counts_file="${COUNTS_DIR}/${sample}_counts.txt"

    filtered_tmp="${filtered_fastq}.partial"
    full_length_tmp="${full_length_fastq}.partial"
    bam_tmp="${sorted_bam}.partial"
    counts_tmp="${counts_file}.partial"

    sample_tmp="${TMP_DIR}/${sample}"
    CURRENT_SAMPLE="${sample}"
    CURRENT_TMP_DIR="${sample_tmp}"

    # Pulisce soltanto residui incompleti del campione corrente.
    rm -rf "${sample_tmp}"
    mkdir -p "${sample_tmp}"
    rm -f \
        "${filtered_tmp}" \
        "${full_length_tmp}" \
        "${bam_tmp}" \
        "${bam_tmp}.bai" \
        "${counts_tmp}" \
        "${counts_tmp}.summary"

    CURRENT_STAGE="verifica FASTQ"
    check_readable_fastq "${barcode_dir}"

    # Un file di conteggio completo significa che il campione è terminato.
    if [[ -s "${counts_file}" ]]; then
        ln -sfn "${counts_file}" "${DESEQ2_DIR}/$(basename "${counts_file}")"
        printf '\n[%s] già completato: salto il campione\n' "${sample}"
        rm -rf "${sample_tmp}"
        CURRENT_TMP_DIR=""
        return 0
    fi

    # --------------------------------------------------------------------------
    # FASTCAT
    # Ogni campione usa una directory di lavoro diversa. In questo modo le
    # cartelle automatiche fastcat-qc/fastcat-histograms non possono collidere.
    # --------------------------------------------------------------------------
    if [[ -s "${filtered_fastq}" ]]; then
        printf '\n[%s] fastcat già completato: riuso output\n' "${sample}"
    else
        CURRENT_STAGE="fastcat"
        printf '\n[%s] fastcat\n' "${sample}"

        mkdir -p "${sample_tmp}/fastcat"
        (
            cd "${sample_tmp}/fastcat"
            run_fastcat fastq \
                -x \
                --min-length "${MIN_LENGTH}" \
                --min-qscore "${MIN_QSCORE}" \
                "${barcode_dir}"
        ) > "${filtered_tmp}"

        require_nonempty_file "${filtered_tmp}"
        mv -f "${filtered_tmp}" "${filtered_fastq}"
        rm -rf "${sample_tmp}/fastcat"
    fi

    # --------------------------------------------------------------------------
    # PYCHOPPER
    # --------------------------------------------------------------------------
    if [[ -s "${full_length_fastq}" ]]; then
        printf '[%s] Pychopper già completato: riuso output\n' "${sample}"
    else
        CURRENT_STAGE="Pychopper"
        printf '[%s] Pychopper\n' "${sample}"

        pychopper_args=(-t "${THREADS}")
        if [[ -n "${PYCHOPPER_KIT}" ]]; then
            pychopper_args+=(-k "${PYCHOPPER_KIT}")
        fi

        mkdir -p "${sample_tmp}/pychopper"
        (
            cd "${sample_tmp}/pychopper"
            run_pychopper \
                "${pychopper_args[@]}" \
                "${filtered_fastq}" \
                "${full_length_tmp}"
        )

        require_nonempty_file "${full_length_tmp}"
        mv -f "${full_length_tmp}" "${full_length_fastq}"
        rm -rf "${sample_tmp}/pychopper"
    fi

    # --------------------------------------------------------------------------
    # MINIMAP2 + SAMTOOLS SORT
    # --------------------------------------------------------------------------
    if [[ -s "${sorted_bam}" ]] && "${SAMTOOLS}" quickcheck "${sorted_bam}"; then
        printf '[%s] BAM già completato: riuso output\n' "${sample}"
    else
        rm -f "${sorted_bam}" "${sorted_bam}.bai"
        CURRENT_STAGE="minimap2 e samtools sort"
        printf '[%s] minimap2 + samtools sort\n' "${sample}"

        mkdir -p "${sample_tmp}/samtools"
        "${MINIMAP2}" \
            -t "${THREADS}" \
            -ax splice \
            -uf \
            --secondary=no \
            "${REF}" \
            "${full_length_fastq}" \
        | "${SAMTOOLS}" sort \
            -@ "${THREADS}" \
            -T "${sample_tmp}/samtools/sort" \
            -o "${bam_tmp}" \
            -

        require_nonempty_file "${bam_tmp}"
        "${SAMTOOLS}" quickcheck "${bam_tmp}"
        mv -f "${bam_tmp}" "${sorted_bam}"
        rm -rf "${sample_tmp}/samtools"
    fi

    # --------------------------------------------------------------------------
    # FEATURECOUNTS
    # --------------------------------------------------------------------------
    CURRENT_STAGE="featureCounts"
    printf '[%s] featureCounts\n' "${sample}"

    mkdir -p "${sample_tmp}/featurecounts"
    (
        cd "${sample_tmp}/featurecounts"
        "${FEATURECOUNTS}" \
            -L \
            -s "${FEATURECOUNTS_STRAND}" \
            -a "${GTF}" \
            -o "${counts_tmp}" \
            -t exon \
            -g gene_id \
            "${sorted_bam}"
    )

    require_nonempty_file "${counts_tmp}"
    mv -f "${counts_tmp}" "${counts_file}"

    # Il report è utile ma non è necessario per DESeq2.
    if [[ -f "${counts_tmp}.summary" ]]; then
        mv -f "${counts_tmp}.summary" "${counts_file}.summary" 2>/dev/null \
            || warn "Impossibile rinominare il report ${counts_tmp}.summary"
    fi

    ln -sfn "${counts_file}" "${DESEQ2_DIR}/$(basename "${counts_file}")"

    rm -rf "${sample_tmp}"
    CURRENT_TMP_DIR=""
    printf '[%s] completato\n' "${sample}"
}

# ==============================================================================
# CONTROLLI INIZIALI ESSENZIALI
# ==============================================================================

[[ -d "${FASTQ_DIR}" && -r "${FASTQ_DIR}" && -x "${FASTQ_DIR}" ]] \
    || die "Cartella FASTQ non leggibile: ${FASTQ_DIR}"

require_readable_file "${REF}"
require_readable_file "${GTF}"

require_executable "${FASTCAT}"
require_executable "${PYCHOPPER}"
require_executable "${NHMMSCAN}"
require_executable "${MINIMAP2}"
require_executable "${SAMTOOLS}"
require_executable "${FEATURECOUNTS}"

[[ "${THREADS}" =~ ^[1-9][0-9]*$ ]] \
    || die "THREADS deve essere un intero maggiore di zero"

[[ "${MIN_LENGTH}" =~ ^[0-9]+$ ]] \
    || die "MIN_LENGTH deve essere un intero non negativo"

[[ "${MIN_QSCORE}" =~ ^[0-9]+([.][0-9]+)?$ ]] \
    || die "MIN_QSCORE deve essere un numero non negativo"

case "${FEATURECOUNTS_STRAND}" in
    0|1|2) ;;
    *) die "FEATURECOUNTS_STRAND deve essere 0, 1 oppure 2" ;;
esac

case "${RUN_DESEQ2}" in
    0|1) ;;
    *) die "RUN_DESEQ2 deve essere 0 oppure 1" ;;
esac

if [[ "${RUN_DESEQ2}" == "1" ]]; then
    require_readable_file "${R_SCRIPT}"
    require_executable "${RSCRIPT}"

    # Controllo rapido: evita di scoprire a fine pipeline uno script R non valido.
    env \
        PATH="${R_ENV}/bin:${PATH}" \
        R_HOME="${R_ENV}/lib/R" \
        "${RSCRIPT}" -e '
            a <- commandArgs(trailingOnly = TRUE)
            parse(file = a[1])
            if (!requireNamespace("DESeq2", quietly = TRUE)) {
                stop("Pacchetto R DESeq2 non disponibile")
            }
        ' "${R_SCRIPT}" >/dev/null
fi

# Verifica reale del comando esterno richiesto da Pychopper.
env PATH="${PYCHOPPER_ENV}/bin:${PATH}" "${NHMMSCAN}" -h >/dev/null

# Controlla tutti i barcode prima di iniziare una lavorazione lunga.
for barcode in "${CONTROL_BARCODES[@]}"; do
    check_readable_fastq "${FASTQ_DIR}/barcode${barcode}"
done
for barcode in "${TREATMENT_BARCODES[@]}"; do
    check_readable_fastq "${FASTQ_DIR}/barcode${barcode}"
done

# ==============================================================================
# DIRECTORY DI OUTPUT
# ==============================================================================

FASTQ_DIR="$(realpath -e "${FASTQ_DIR}")"
OUTPUT_PARENT="$(dirname "${FASTQ_DIR}")"
RUN_ID="$(date '+%Y%m%d_%H%M%S')"
OUTPUT_ROOT="${OUTPUT_ROOT:-${OUTPUT_PARENT}/${BATCH_NAME}_bulk_output_${RUN_ID}}"

mkdir -p "${OUTPUT_ROOT}"
OUTPUT_ROOT="$(realpath -e "${OUTPUT_ROOT}")"

FASTCAT_DIR="${OUTPUT_ROOT}/01_fastcat"
PYCHOPPER_DIR="${OUTPUT_ROOT}/02_pychopper"
BAM_DIR="${OUTPUT_ROOT}/03_bam"
COUNTS_DIR="${OUTPUT_ROOT}/04_featurecounts"
DESEQ2_DIR="${OUTPUT_ROOT}/05_deseq2"
TMP_DIR="${OUTPUT_ROOT}/.tmp"

mkdir -p \
    "${FASTCAT_DIR}" \
    "${PYCHOPPER_DIR}" \
    "${BAM_DIR}" \
    "${COUNTS_DIR}" \
    "${DESEQ2_DIR}" \
    "${TMP_DIR}"

# Residui dei tentativi precedenti di fastcat non vengono mai riutilizzati.
rm -rf \
    "${FASTCAT_DIR}/fastcat-qc" \
    "${FASTCAT_DIR}/fastcat-histograms" 2>/dev/null || true

printf 'Input : %s\n' "${FASTQ_DIR}"
printf 'Output: %s\n' "${OUTPUT_ROOT}"

# ==============================================================================
# ELABORAZIONE DEI CAMPIONI
# ==============================================================================

for barcode in "${CONTROL_BARCODES[@]}"; do
    process_sample "${barcode}" "${CONTROL_LABEL}"
done

for barcode in "${TREATMENT_BARCODES[@]}"; do
    process_sample "${barcode}" "${TREATMENT_LABEL}"
done

# Tutti i conteggi devono essere presenti prima di DESeq2.
CURRENT_SAMPLE="tutti i campioni"
CURRENT_STAGE="verifica conteggi"

EXPECTED_SAMPLES=$(( ${#CONTROL_BARCODES[@]} + ${#TREATMENT_BARCODES[@]} ))
COUNT_FILES=("${DESEQ2_DIR}"/*_counts.txt)

if (( ${#COUNT_FILES[@]} != EXPECTED_SAMPLES )); then
    die "Attesi ${EXPECTED_SAMPLES} file di conteggio, trovati ${#COUNT_FILES[@]} in ${DESEQ2_DIR}"
fi

for count_file in "${COUNT_FILES[@]}"; do
    require_nonempty_file "${count_file}"
done

# ==============================================================================
# DESEQ2
# ==============================================================================

if [[ "${RUN_DESEQ2}" == "1" ]]; then
    CURRENT_STAGE="DESeq2"
    printf '\n[DESeq2] analisi differenziale\n'

    (
        cd "${DESEQ2_DIR}"
        env \
            PATH="${R_ENV}/bin:${PATH}" \
            R_HOME="${R_ENV}/lib/R" \
            "${RSCRIPT}" \
            "${R_SCRIPT}" \
            "${DESEQ2_DIR}" \
            "${TREATMENT_LABEL}" \
            "${CONTROL_LABEL}"
    )
else
    printf '\nDESeq2 non eseguito perché RUN_DESEQ2=0.\n'
fi

CURRENT_STAGE="pulizia finale"
rm -rf "${TMP_DIR}" 2>/dev/null || true

CURRENT_STAGE="completata"
printf '\nANALISI COMPLETATA\nOutput: %s\n' "${OUTPUT_ROOT}"
