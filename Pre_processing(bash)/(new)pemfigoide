#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'
shopt -s nullglob

# ==============================================================================
# PIPELINE NANOPORE BULK RNA-SEQ — VERSIONE SEMPLICE
#
# Esecuzione:
#   chmod +x pemfigoide_semplice.sh
#   ./pemfigoide_semplice.sh
#
# Ambienti usati:
#   nanopore_bulk_stable
#   nanopore_pychopper
#   nanopore_fastcat
#   nanopore_deseq2
#
# Non eseguire con sudo.
# Lo script chiede sudo soltanto per rendere leggibili gli input FASTQ.
# ==============================================================================

# ==============================================================================
# PARAMETRI
# ==============================================================================

FASTQ_DIR="/home/lab-user/Scrivania/pemfigoide/fastq_pass"

CONTROL_LABEL="SANO"
TREATMENT_LABEL="PB"

CONTROL_BARCODES=(01 02 03 04 05 06)
TREATMENT_BARCODES=(07 08 09 10 11 13)

BATCH_NAME="Batch1"
THREADS=30

R_SCRIPT="/home/lab-user/reference/deseq_auto_import.r"
REF="/home/lab-user/reference/Homo_sapiens.GRCh38.dna.primary_assembly.fa"
GTF="/home/lab-user/reference/gtf_human/BULK_HUMAN_G38.gtf"

CONDA_BASE="/home/lab-user/miniforge3"

MIN_LENGTH=500
MIN_QSCORE=10
FEATURECOUNTS_STRAND=0

# Lasciare vuoto per usare il kit predefinito di Pychopper.
PYCHOPPER_KIT=""

# ==============================================================================
# FUNZIONI SEMPLICI
# ==============================================================================

log() {
    printf '\n[%s] %s\n' "$(date '+%F %T')" "$*"
}

die() {
    printf '\n❌ ERRORE: %s\n' "$*" >&2
    exit 1
}

sample_name() {
    local barcode="$1"
    local label="$2"
    printf '%s_barcode_%s_%s' "${BATCH_NAME}" "${barcode}" "${label}"
}

activate_env() {
    local env_path="$1"

    # shellcheck source=/dev/null
    source "${CONDA_BASE}/etc/profile.d/conda.sh"
    conda activate "${env_path}"

    printf 'Ambiente attivo: %s\n' "${CONDA_PREFIX}"
}

deactivate_env() {
    conda deactivate
}

combine_fastqs() {
    local barcode="$1"
    local output_fastq="$2"
    local barcode_dir="${FASTQ_DIR}/barcode${barcode}"
    local -a files=()

    mapfile -d '' files < <(
        find "${barcode_dir}" \
            -type f \
            \( \
                -iname '*.fastq.gz' -o \
                -iname '*.fq.gz'    -o \
                -iname '*.fastq'    -o \
                -iname '*.fq' \
            \) \
            -print0 \
        | sort -z
    )

    (( ${#files[@]} > 0 )) \
        || die "Nessun FASTQ trovato in ${barcode_dir}"

    : > "${output_fastq}"

    local file
    local lower

    for file in "${files[@]}"; do
        lower="${file,,}"

        case "${lower}" in
            *.fastq.gz|*.fq.gz)
                gzip -cd -- "${file}" >> "${output_fastq}"
                ;;
            *.fastq|*.fq)
                cat -- "${file}" >> "${output_fastq}"
                ;;
        esac
    done

    [[ -s "${output_fastq}" ]] \
        || die "FASTQ combinato vuoto: ${output_fastq}"

    printf 'File FASTQ combinati per barcode%s: %s\n' \
        "${barcode}" "${#files[@]}"
}

# ==============================================================================
# CONTROLLI INIZIALI
# ==============================================================================

[[ "${EUID}" -ne 0 ]] \
    || die "Non eseguire la pipeline con sudo."

[[ -d "${FASTQ_DIR}" ]] \
    || die "Cartella FASTQ non trovata: ${FASTQ_DIR}"

[[ -r "${REF}" ]] \
    || die "FASTA non trovato o non leggibile: ${REF}"

[[ -r "${GTF}" ]] \
    || die "GTF non trovato o non leggibile: ${GTF}"

[[ -r "${R_SCRIPT}" ]] \
    || die "Script R non trovato o non leggibile: ${R_SCRIPT}"

[[ -f "${CONDA_BASE}/etc/profile.d/conda.sh" ]] \
    || die "Conda non trovato in ${CONDA_BASE}"

MAIN_ENV="${CONDA_BASE}/envs/nanopore_bulk_stable"
PYCHOPPER_ENV="${CONDA_BASE}/envs/nanopore_pychopper"
FASTCAT_ENV="${CONDA_BASE}/envs/nanopore_fastcat"
R_ENV="${CONDA_BASE}/envs/nanopore_deseq2"

[[ -d "${MAIN_ENV}" ]] \
    || die "Ambiente mancante: ${MAIN_ENV}"

[[ -d "${PYCHOPPER_ENV}" ]] \
    || die "Ambiente mancante: ${PYCHOPPER_ENV}"

[[ -d "${FASTCAT_ENV}" ]] \
    || die "Ambiente mancante: ${FASTCAT_ENV}"

[[ -d "${R_ENV}" ]] \
    || die "Ambiente mancante: ${R_ENV}"

case "${FEATURECOUNTS_STRAND}" in
    0|1|2) ;;
    *) die "FEATURECOUNTS_STRAND deve essere 0, 1 oppure 2." ;;
esac

AVAILABLE_THREADS="$(nproc)"

if (( THREADS > AVAILABLE_THREADS )); then
    THREADS="${AVAILABLE_THREADS}"
fi

# Concede soltanto lettura dei file e attraversamento delle cartelle.
log "Impostazione dei permessi di lettura sugli input..."
sudo chmod -R a+rX "${FASTQ_DIR}"

# Verifica le cartelle barcode.
ALL_BARCODES=("${CONTROL_BARCODES[@]}" "${TREATMENT_BARCODES[@]}")

for barcode in "${ALL_BARCODES[@]}"; do
    [[ -d "${FASTQ_DIR}/barcode${barcode}" ]] \
        || die "Cartella mancante: ${FASTQ_DIR}/barcode${barcode}"
done

# ==============================================================================
# CARTELLE OUTPUT
#
# Ogni esecuzione crea una cartella nuova e indipendente.
# ==============================================================================

FASTQ_DIR="$(realpath "${FASTQ_DIR}")"
OUTPUT_PARENT="$(dirname "${FASTQ_DIR}")"
RUN_ID="$(date '+%Y%m%d_%H%M%S')_$$"

OUTPUT_ROOT="${OUTPUT_PARENT}/${BATCH_NAME}_bulk_output_${RUN_ID}"

COMBINED_DIR="${OUTPUT_ROOT}/00_combined_fastq"
NANOPLOT_DIR="${OUTPUT_ROOT}/01_nanoplot"
FASTCAT_DIR="${OUTPUT_ROOT}/02_fastcat"
PYCHOPPER_DIR="${OUTPUT_ROOT}/03_pychopper"
MINIMAP2_DIR="${OUTPUT_ROOT}/04_minimap2"
SAMTOOLS_DIR="${OUTPUT_ROOT}/05_samtools"
FEATURECOUNTS_DIR="${OUTPUT_ROOT}/06_featurecounts"
DESEQ2_DIR="${OUTPUT_ROOT}/07_deseq2"
LOG_DIR="${OUTPUT_ROOT}/08_logs"

mkdir -p \
    "${COMBINED_DIR}" \
    "${NANOPLOT_DIR}" \
    "${FASTCAT_DIR}" \
    "${PYCHOPPER_DIR}" \
    "${MINIMAP2_DIR}" \
    "${SAMTOOLS_DIR}" \
    "${FEATURECOUNTS_DIR}" \
    "${DESEQ2_DIR}" \
    "${LOG_DIR}"

LOG_FILE="${LOG_DIR}/pipeline.log"
exec > >(tee -a "${LOG_FILE}") 2>&1

log "Input : ${FASTQ_DIR}"
log "Output: ${OUTPUT_ROOT}"
log "Thread: ${THREADS}"

# Costruisce l'elenco dei campioni una sola volta.
SAMPLE_BARCODES=()
SAMPLE_LABELS=()

for barcode in "${CONTROL_BARCODES[@]}"; do
    SAMPLE_BARCODES+=("${barcode}")
    SAMPLE_LABELS+=("${CONTROL_LABEL}")
done

for barcode in "${TREATMENT_BARCODES[@]}"; do
    SAMPLE_BARCODES+=("${barcode}")
    SAMPLE_LABELS+=("${TREATMENT_LABEL}")
done

# ==============================================================================
# 1. COMBINAZIONE FASTQ E NANOPLOT
# Ambiente: nanopore_bulk_stable
# ==============================================================================

log "FASE 1 — Combinazione FASTQ e NanoPlot"

activate_env "${MAIN_ENV}"

for i in "${!SAMPLE_BARCODES[@]}"; do
    barcode="${SAMPLE_BARCODES[$i]}"
    label="${SAMPLE_LABELS[$i]}"
    sample="$(sample_name "${barcode}" "${label}")"

    combined_fastq="${COMBINED_DIR}/${sample}_combined.fastq"
    nanoplot_sample_dir="${NANOPLOT_DIR}/${sample}"

    log "Combinazione e NanoPlot: ${sample}"

    combine_fastqs "${barcode}" "${combined_fastq}"

    mkdir -p "${nanoplot_sample_dir}"

    NanoPlot \
        -t "${THREADS}" \
        --fastq "${combined_fastq}" \
        --outdir "${nanoplot_sample_dir}"
done

deactivate_env

# ==============================================================================
# 2. FASTCAT
# Ambiente: nanopore_fastcat
#
# Ogni campione viene eseguito nella propria cartella.
# L'eventuale cartella predefinita fastcat-qc non entra quindi in conflitto
# con quella degli altri campioni.
# ==============================================================================

log "FASE 2 — Filtraggio fastcat"

activate_env "${FASTCAT_ENV}"

for i in "${!SAMPLE_BARCODES[@]}"; do
    barcode="${SAMPLE_BARCODES[$i]}"
    label="${SAMPLE_LABELS[$i]}"
    sample="$(sample_name "${barcode}" "${label}")"

    combined_fastq="${COMBINED_DIR}/${sample}_combined.fastq"
    fastcat_sample_dir="${FASTCAT_DIR}/${sample}"
    filtered_fastq="${fastcat_sample_dir}/${sample}_filtered.fastq"
    fastcat_log="${fastcat_sample_dir}/${sample}_fastcat.log"

    log "fastcat: ${sample}"

    mkdir -p "${fastcat_sample_dir}"

    (
        cd "${fastcat_sample_dir}"

        fastcat fastq \
            --min-length "${MIN_LENGTH}" \
            --min-qscore "${MIN_QSCORE}" \
            "${combined_fastq}" \
            > "${filtered_fastq}" \
            2> "${fastcat_log}"
    )

    [[ -s "${filtered_fastq}" ]] \
        || die "FASTQ filtrato vuoto: ${filtered_fastq}"

    rm -f -- "${combined_fastq}"
done

deactivate_env

# ==============================================================================
# 3. PYCHOPPER
# Ambiente: nanopore_pychopper
# ==============================================================================

log "FASE 3 — Pychopper"

activate_env "${PYCHOPPER_ENV}"

for i in "${!SAMPLE_BARCODES[@]}"; do
    barcode="${SAMPLE_BARCODES[$i]}"
    label="${SAMPLE_LABELS[$i]}"
    sample="$(sample_name "${barcode}" "${label}")"

    filtered_fastq="${FASTCAT_DIR}/${sample}/${sample}_filtered.fastq"
    pychopper_sample_dir="${PYCHOPPER_DIR}/${sample}"
    full_length_fastq="${pychopper_sample_dir}/${sample}_full_length.fastq"
    unclassified_fastq="${pychopper_sample_dir}/${sample}_unclassified.fastq"
    pychopper_report="${pychopper_sample_dir}/${sample}_pychopper_report.pdf"
    pychopper_log="${pychopper_sample_dir}/${sample}_pychopper.log"

    log "Pychopper: ${sample}"

    mkdir -p "${pychopper_sample_dir}"

    pychopper_args=(
        -t "${THREADS}"
        -r "${pychopper_report}"
        -u "${unclassified_fastq}"
    )

    if [[ -n "${PYCHOPPER_KIT}" ]]; then
        pychopper_args+=(-k "${PYCHOPPER_KIT}")
    fi

    pychopper \
        "${pychopper_args[@]}" \
        "${filtered_fastq}" \
        "${full_length_fastq}" \
        2>&1 | tee "${pychopper_log}"

    [[ -s "${full_length_fastq}" ]] \
        || die "Pychopper non ha prodotto read full-length: ${sample}"
done

deactivate_env

# ==============================================================================
# 4. MINIMAP2 E SAMTOOLS
# Ambiente: nanopore_bulk_stable
# ==============================================================================

log "FASE 4 — minimap2 e samtools"

activate_env "${MAIN_ENV}"

for i in "${!SAMPLE_BARCODES[@]}"; do
    barcode="${SAMPLE_BARCODES[$i]}"
    label="${SAMPLE_LABELS[$i]}"
    sample="$(sample_name "${barcode}" "${label}")"

    full_length_fastq="${PYCHOPPER_DIR}/${sample}/${sample}_full_length.fastq"
    minimap2_sample_dir="${MINIMAP2_DIR}/${sample}"
    samtools_sample_dir="${SAMTOOLS_DIR}/${sample}"
    minimap2_log="${minimap2_sample_dir}/${sample}_minimap2.log"
    sorted_bam="${samtools_sample_dir}/${sample}_sorted.bam"
    flagstat_file="${samtools_sample_dir}/${sample}_flagstat.txt"

    log "Allineamento: ${sample}"

    mkdir -p \
        "${minimap2_sample_dir}" \
        "${samtools_sample_dir}"

    minimap2 \
        -t "${THREADS}" \
        -ax splice \
        -uf \
        --secondary=no \
        "${REF}" \
        "${full_length_fastq}" \
        2> "${minimap2_log}" \
    | samtools sort \
        -@ "${THREADS}" \
        -o "${sorted_bam}" \
        -

    [[ -s "${sorted_bam}" ]] \
        || die "BAM ordinato vuoto: ${sample}"

    samtools quickcheck "${sorted_bam}"
    samtools index -@ "${THREADS}" "${sorted_bam}"
    samtools flagstat -@ "${THREADS}" "${sorted_bam}" > "${flagstat_file}"
done

deactivate_env

# ==============================================================================
# 5. FEATURECOUNTS
# Ambiente: nanopore_bulk_stable
# ==============================================================================

log "FASE 5 — featureCounts"

activate_env "${MAIN_ENV}"

for i in "${!SAMPLE_BARCODES[@]}"; do
    barcode="${SAMPLE_BARCODES[$i]}"
    label="${SAMPLE_LABELS[$i]}"
    sample="$(sample_name "${barcode}" "${label}")"

    sorted_bam="${SAMTOOLS_DIR}/${sample}/${sample}_sorted.bam"
    featurecounts_sample_dir="${FEATURECOUNTS_DIR}/${sample}"
    counts_file="${featurecounts_sample_dir}/${sample}_counts.txt"
    featurecounts_log="${featurecounts_sample_dir}/${sample}_featureCounts.log"

    log "featureCounts: ${sample}"

    mkdir -p "${featurecounts_sample_dir}"

    featureCounts \
        -L \
        -T "${THREADS}" \
        -s "${FEATURECOUNTS_STRAND}" \
        -a "${GTF}" \
        -o "${counts_file}" \
        -t exon \
        -g gene_id \
        "${sorted_bam}" \
        > "${featurecounts_log}" \
        2>&1

    [[ -s "${counts_file}" ]] \
        || die "File counts vuoto: ${sample}"

    cp -- "${counts_file}" "${DESEQ2_DIR}/"
done

deactivate_env

# ==============================================================================
# 6. DESEQ2
# Ambiente: nanopore_deseq2
# ==============================================================================

log "FASE 6 — DESeq2"

activate_env "${R_ENV}"

(
    cd "${DESEQ2_DIR}"

    Rscript \
        "${R_SCRIPT}" \
        "${DESEQ2_DIR}" \
        "${TREATMENT_LABEL}" \
        "${CONTROL_LABEL}"
)

deactivate_env

# ==============================================================================
# FINE
# ==============================================================================

cat <<EOF

==============================================================================
✅ PIPELINE COMPLETATA
==============================================================================

Output:
    ${OUTPUT_ROOT}

Cartelle:
    01_nanoplot
    02_fastcat
    03_pychopper
    04_minimap2
    05_samtools
    06_featurecounts
    07_deseq2
    08_logs

Log:
    ${LOG_FILE}

==============================================================================
EOF
